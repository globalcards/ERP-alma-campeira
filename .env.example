# ─── Banco de dados (PostgreSQL / Prisma) ───────────────────────────────────
# Ambiente local padrão:
#   host: localhost
#   porta: 5432
#   database: erp_alma
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/erp_alma

# ─── Auth / Sessão ───────────────────────────────────────────────────────────
# Segredo para assinar JWTs de sessão.
JWT_SECRET=troque-por-um-segredo-longo

# Em ambiente local HTTP, mantenha false.
COOKIE_SECURE=false

# ─── Storage ────────────────────────────────────────────────────────────────
# Diretório base onde uploads e imagens são salvos localmente.
UPLOADS_DIR=./.uploads-local

# URL pública da aplicação local.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
